# ── Neon DB (PostgreSQL) ────────────────────────────────────────────────────
# Use the "pooled" connection string for runtime Prisma clients.
# Use the "direct" connection string as Prisma directUrl for migrations only.
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/voiceagent?sslmode=require
DATABASE_URL_DIRECT=postgresql://user:password@ep-xxxx-direct.us-east-2.aws.neon.tech/voiceagent?sslmode=require

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Node Gateway ────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
VAPI_WEBHOOK_SECRET=replace_with_real_secret
VAPI_API_KEY=replace_with_vapi_api_key
VAPI_ASSISTANT_ID=replace_with_vapi_assistant_id
FASTAPI_BRAIN_URL=http://fastapi-brain:8000
INTERNAL_SERVICE_SECRET=replace_with_random_secret_min_32_chars
ADMIN_SECRET=replace_with_admin_secret
LOG_LEVEL=debug

# ── FastAPI Brain ────────────────────────────────────────────────────────────
OPENAI_API_KEY=replace_with_real_key
OPENAI_MODEL=gpt-4o
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini
NODE_GATEWAY_URL=http://node-gateway:3000
PINECONE_API_KEY=
PINECONE_INDEX_NAME=voice-agent-products

# Hybrid objection classifier (Phase B-1).
# Index name for the embedded objection seed labels.
PINECONE_OBJECTIONS_INDEX_NAME=voice-agent-objections
# Mode: "shadow" (run both, return LLM, log Pinecone for offline comparison)
#       "pinecone" (Pinecone first, LLM fallback on low confidence/error)
#       "llm" (kill switch — original LLM-only behavior)
CLASSIFIER_MODE=shadow
# Top-3 must agree AND average similarity must be >= this for a "consensus" win.
CLASSIFIER_CONFIDENCE_THRESHOLD=0.78
# If top-1 similarity is >= this, it wins outright as a "strict" win.
CLASSIFIER_TOP1_STRICT_THRESHOLD=0.85
