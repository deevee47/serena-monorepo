# ─────────────────────────────────────────────────────────────────────────────
# Coolify environment variables for the Serena stack (docker-compose.coolify.yml).
# Paste these into the Coolify resource's "Environment Variables" tab and fill in
# real values. Coolify injects them into every service in the compose file.
#
# DO NOT set these here — the compose file pins them to the internal service names:
#   PORT, REDIS_URL, FASTAPI_BRAIN_URL, NODE_GATEWAY_URL, GATEWAY_URL,
#   NODE_ENV, ENVIRONMENT
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres (external Neon) ────────────────────────────────────────────────
# Pooled connection string for runtime; direct (non-pooled) for migrations.
DATABASE_URL=postgresql://USER:PASS@ep-xxxx-pooler.REGION.aws.neon.tech/voiceagent?sslmode=require
DATABASE_URL_DIRECT=postgresql://USER:PASS@ep-xxxx.REGION.aws.neon.tech/voiceagent?sslmode=require

# ── Public domain (bare host, no scheme) ────────────────────────────────────
# Read by next.config.ts to allow Server Actions from the prod dashboard origin.
# Mark this variable as AVAILABLE AT BUILD TIME in Coolify (it's a build arg).
DASHBOARD_DOMAIN=app.example.com

# ── OpenAI (brain) ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini

# ── Pinecone (brain) ────────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=voice-agent-products
PINECONE_OBJECTIONS_INDEX_NAME=voice-agent-objections
CLASSIFIER_MODE=shadow
CLASSIFIER_CONFIDENCE_THRESHOLD=0.78
CLASSIFIER_TOP1_STRICT_THRESHOLD=0.85

# ── Gateway secrets ─────────────────────────────────────────────────────────
INTERNAL_SERVICE_SECRET=        # `openssl rand -hex 32`
ADMIN_SECRET=                   # `openssl rand -hex 24`
LOG_LEVEL=info

# ── Voice provider ──────────────────────────────────────────────────────────
# VOICE_PROVIDER defaults to "vapi". The gateway WILL NOT BOOT unless the three
# vars for the active provider are set (env.ts superRefine).
VOICE_PROVIDER=vapi
VAPI_WEBHOOK_SECRET=            # required when VOICE_PROVIDER=vapi
VAPI_API_KEY=                   # required when VOICE_PROVIDER=vapi
VAPI_ASSISTANT_ID=             # required when VOICE_PROVIDER=vapi
VAPI_PUBLIC_KEY=               # browser-side, powers the /talk page
VAPI_PHONE_NUMBER_ID=          # optional — number to dial from on outbound
# The PUBLIC gateway URL Vapi calls in Custom-LLM mode:
VAPI_CUSTOM_LLM_URL=https://api.example.com/llm/chat/completions
# Optional provider voice IDs (timezone-aware):
VAPI_VOICE_EN=
VAPI_VOICE_HI=
#
# If VOICE_PROVIDER=telnyx, set these instead (see README "Environment Variables"):
#   TELNYX_API_KEY, TELNYX_PUBLIC_KEY, TELNYX_ASSISTANT_ID and
#   LLM_URL=https://api.example.com/llm/chat/completions

# ── Dashboard ───────────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=            # shared login password for the admin UI
DASHBOARD_SESSION_SECRET=      # `openssl rand -hex 16`
GATEWAY_ADMIN_SECRET=          # MUST equal ADMIN_SECRET above
